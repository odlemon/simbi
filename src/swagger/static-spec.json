                  "price": { "type": "number", "minimum": 0 },
                  "quantity": { "type": "integer", "minimum": 0 },
                  "condition": { "type": "string", "enum": ["NEW", "USED", "REFURBISHED"] },
                  "description": { "type": "string" },
                  "images": { "type": "array", "items": { "type": "string" } }
