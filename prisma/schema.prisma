model Order {
  id                    String                      @id @default(uuid())
  orderNumber           String                      @unique
  buyerId               String?                     // Nullable for individual/guest buyers
  sellerId              String
  addressId             String?                     // Nullable for guest orders (address stored separately)
  poNumber              String?
  costCenter            String?
  subtotal              Float
  shippingCost          Float
  platformCommission    Float
  discountAmount        Float                        @default(0) // Coupon discount amount
  couponCode            String?                     // Applied coupon code
  totalAmount           Float
  currency              Currency
  exchangeRate          Float?
  exchangeRateTimestamp DateTime?
  status                OrderStatus                 @default(PENDING_PAYMENT)
  paymentStatus         PaymentStatus               @default(PENDING)
  sellerAcceptedAt      DateTime?
  sellerRejectedAt      DateTime?
  rejectionReason       String?                     @db.Text
  estimatedDeliveryDate DateTime?
  actualDeliveryDate    DateTime?
  ipAddress             String?
  userAgent             String?
  // Driver dispatch fields (admin managed)
  driverId              String?
  dispatchNotes         String?                     @db.Text
  dispatchedAt          DateTime?
  dispatchedBy          String?                     // Admin ID who dispatched
  // Evidence Chain of Custody (ECC) fields
  eccBaselineUploaded   Boolean                     @default(false)
  eccBaselineUploadedAt DateTime?
  eccBaselineUrls       Json?                       // Pre-shipment evidence URLs
  // Guest checkout fields (for individual buyers without accounts)
  isGuestOrder          Boolean                     @default(false)
  guestAccessToken      String?                     // Cryptographic token for guest tracking
  mobileNumber          String?                     // For guest orders (identity anchor)
  paymentToken          String?                     // Tokenized card data (PCI DSS compliant)
  // Individual buyer information (when buyerId is null)
  guestFirstName        String?                     // First name for individual buyers
  guestLastName         String?                     // Last name for individual buyers
  guestEmail            String?                     // Email for individual buyers
  guestPhoneNumber      String?                     // Phone number for individual buyers
  // Guest shipping address (when addressId is null)
  guestShippingPhoneNumber String?                 // Phone number for shipping
  guestShippingAddressLine1 String?                // Address line 1
  guestShippingAddressLine2 String?                // Address line 2
  guestShippingCity        String?                 // City
  guestShippingProvince    String?                 // Province
  guestShippingPostalCode  String?                 // Postal code
  /// Snapshot from ShippingQuoteService when commerce.shipping.engine is carrier_v1 (audit).
  shippingQuoteSnapshot Json?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt
  disputes              Dispute?
  items                 OrderItem[]
  shippingAddress       BuyerAddress?               @relation(fields: [addressId], references: [id]) // Optional for guest orders
  buyer                 Buyer?                      @relation(fields: [buyerId], references: [id]) // Optional for guest orders
  seller                Seller                      @relation(fields: [sellerId], references: [id])
  driver                Driver?                     @relation(fields: [driverId], references: [id])
  gatewayTransactions   PaymentGatewayTransaction[]
  payment               Payment?
  payout                Payout?
  adminNotifications    AdminNotification[]          @relation("AdminNotificationOrder")
  buyerNotifications    BuyerNotification[]          @relation("BuyerNotificationOrder")
  sellerNotifications   SellerNotification[]          @relation("SellerNotificationOrder")
  shipment              Shipment?
  couponUsage           CouponUsage?
  reviews               Review[]
  guestOrder            GuestOrder?
  threeWayMatch         ThreeWayMatch?
  taxInvoice            TaxInvoice?

  @@index([buyerId])
  @@index([sellerId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([driverId])
  @@index([addressId], map: "orders_addressId_fkey")
  @@map("orders")
}

model OrderItem {
  id           String          @id @default(uuid())
  orderId      String
  inventoryId  String
  quantity     Int
  unitPrice    Float
  displayPrice Float
  commission   Float
  createdAt    DateTime        @default(now())
  inventory    SellerInventory @relation(fields: [inventoryId], references: [id])
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviews      Review[]

  @@index([orderId])
  @@index([inventoryId], map: "order_items_inventoryId_fkey")
  @@map("order_items")
}

model Review {
  id            String          @id @default(uuid())
  inventoryId   String
  buyerId       String
  orderId       String
  orderItemId   String
  rating        Int             // 1-5 stars
  title         String
  comment       String?         @db.Text
  status        ReviewStatus    @default(APPROVED) // Auto-approve
  flaggedReason String?         @db.Text
  moderatedBy   String?         // Admin ID who moderated
  moderatedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  inventory     SellerInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  buyer         Buyer           @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem     OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  response      ReviewResponse?
  moderations   ReviewModeration[]

  @@unique([buyerId, inventoryId]) // One review per buyer per inventory item
  @@index([inventoryId])
  @@index([buyerId])
  @@index([orderId])
  @@index([status])
  @@index([rating])
  @@index([createdAt])
  @@map("reviews")
}

model ReviewResponse {
  id        String   @id @default(uuid())
  reviewId  String   @unique
  sellerId  String
  response  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  seller    Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([sellerId])
  @@map("review_responses")
}

model ReviewModeration {
  id        String           @id @default(uuid())
  reviewId  String
  adminId   String
  action    ModerationAction // APPROVE, REJECT, FLAG
  reason    String?          @db.Text
  notes     String?          @db.Text
  createdAt DateTime         @default(now())
  review    Review           @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  admin     Admin            @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@index([adminId])
  @@index([action])
  @@index([createdAt])
  @@map("review_moderations")
}

model Payment {
  id                   String                      @id @default(uuid())
  orderId              String                      @unique
  amount               Float
  currency             Currency
  paymentMethod        PaymentMethod
  gatewayProvider      String?
  gatewayTransactionId String?
