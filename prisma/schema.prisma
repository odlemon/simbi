// Simbi Market - Comprehensive Database Schema
// Version: 1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION & RBAC
// ============================================================================

enum UserRole {
  SUPER_ADMIN
  FINOPS_ANALYST
  COMPLIANCE_MANAGER
  LOGISTICS_COORDINATOR
  TECH_SUPPORT
  INDIVIDUAL_BUYER
  ENTERPRISE_BUYER
  SELLER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

model Admin {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String // Argon2id hashed
  firstName     String
  lastName      String
  role          UserRole
  status        UserStatus @default(ACTIVE)
  mfaEnabled    Boolean  @default(false)
  mfaSecret     String?
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  activityLogs     ActivityLog[]
  disputesHandled  Dispute[]
  alertsHandled    AdminAlert[]
  integrations     ExternalIntegration[]
  
  @@map("admins")
  @@index([email])
  @@index([role])
  @@index([status])
}

model ActivityLog {
  id          String   @id @default(uuid())
  adminId     String
  action      String   // e.g., "VIEWED_DOCUMENT", "APPROVED_SELLER", "PROCESSED_PAYOUT"
  entityType  String   // e.g., "Seller", "Order", "Product"
  entityId    String
  ipAddress   String
  userAgent   String?
  metadata    Json?    // Additional context
  createdAt   DateTime @default(now())

  admin       Admin    @relation(fields: [adminId], references: [id])

  @@map("activity_logs")
  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ============================================================================
// MASTER PRODUCT DATABASE (2 Million Parts)
// ============================================================================

enum MeasurementUnit {
  METRIC
  IMPERIAL
}

model MasterProduct {
  id                    String   @id @default(uuid())
  masterPartId          String   @unique // Custom identifier
  oemPartNumber         String   // Original Equipment Manufacturer part number
  name                  String
  description           String   @db.Text
  categoryId            String
  manufacturer          String
  
  // Dimensional data for logistics
  length                Float?
  width                 Float?
  height                Float?
  weight                Float?
  unit                  MeasurementUnit @default(METRIC)
  
  // Vehicle compatibility (JSON array for flexibility)
  vehicleCompatibility  Json     // { make, model, year, engineCode, trimLevel, vinRange }
  
  // Metadata
  imageUrls             Json?    // Array of image URLs
  specSheetUrl          String?
  isActive              Boolean  @default(true)
  isCustom              Boolean  @default(false) // True if admin-approved custom product
  approvedAt            DateTime?
  approvedBy            String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  category              ProductCategory @relation(fields: [categoryId], references: [id])
  sellerInventory       SellerInventory[]
  customRequest         CustomProductRequest?
  quoteRequests         QuoteRequest[]
  
  @@map("master_products")
  @@index([oemPartNumber])
  @@index([categoryId])
  @@index([manufacturer])
  @@index([isActive])
}

model ProductCategory {
  id                String   @id @default(uuid())
  name              String   @unique
  slug              String   @unique
  description       String?  @db.Text
  commissionRate    Float    // Platform commission rate (e.g., 0.10 for 10%)
  parentId          String?  // For hierarchical categories
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  parent            ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children          ProductCategory[] @relation("CategoryHierarchy")
  products          MasterProduct[]
  
  @@map("product_categories")
  @@index([slug])
  @@index([parentId])
}

// ============================================================================
// SELLER MANAGEMENT
// ============================================================================

enum SellerStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  BANNED
}

enum DocumentType {
  ZIMRA_CERTIFICATE
  TIN_CERTIFICATE
  KYC_DOCUMENT
  BUSINESS_REGISTRATION
  TAX_CLEARANCE
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Seller {
  id                    String   @id @default(uuid())
  email                 String   @unique
  password              String   // Argon2id hashed
  businessName          String
  tradingName           String?
  businessAddress       String   @db.Text
  contactNumber         String   // Encrypted
  tin                   String   @unique // Tax Identification Number
  
  // Business details
  registrationNumber    String?
  bankAccountName       String?
  bankAccountNumber     String?  // Encrypted
  bankName              String?
  
  // Status and compliance
  status                SellerStatus @default(ACTIVE)
  sriScore              Float    @default(70) // Seller Reliability Index (0-100)
  lastSriCalculation    DateTime?
  
  // Flags
  mfaEnabled            Boolean  @default(false)
  mfaSecret             String?
  isEligible            Boolean  @default(true) // Above SRI threshold (70)
  isShadowBanned        Boolean  @default(false)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  documents             SellerDocument[]
  inventory             SellerInventory[]
  orders                Order[]
  employees             SellerEmployee[]
  sriHistory            SRIHistory[]
  payouts               Payout[]
  customProductRequests CustomProductRequest[]
  
  // ERP Module Relations
  ledgerEntries         SellerLedger[]
  expenses              SellerExpense[]
  staff                 SellerStaff[]
  loanApplications      LoanApplication[]
  bulkUploads           BulkUpload[]
  integrations          ExternalIntegration[]
  
  // Dispute & Quote Relations
  disputes              Dispute[]
  quoteRequests         QuoteRequest[]
  quoteResponses        QuoteResponse[]
  
  @@map("sellers")
  @@index([email])
  @@index([status])
  @@index([sriScore])
  @@index([isEligible])
}

model SellerDocument {
  id                String   @id @default(uuid())
  sellerId          String
  documentType      DocumentType
  status            DocumentStatus @default(PENDING)
  fileUrl           String   // Encrypted S3 URL
  fileHash          String   // SHA-256 checksum
  issuedDate        DateTime?
  expiryDate        DateTime?
  
  uploadedAt        DateTime @default(now())
  approvedAt        DateTime?
  approvedBy        String?  // Admin ID
  rejectionReason   String?  @db.Text
  
  // Audit trail
  viewLogs          Json?    // Array of {adminId, timestamp, ipAddress}
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller            Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  @@map("seller_documents")
  @@index([sellerId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate])
}

model SRIHistory {
  id                    String   @id @default(uuid())
  sellerId              String
  score                 Float
  
  // Component scores (0.0 - 1.0)
  fulfilmentRate        Float
  onTimeDeliveryRate    Float
  defectRate            Float
  complianceScore       Float
  
  // Metadata
  calculationDate       DateTime @default(now())
  ordersPeriodStart     DateTime
  ordersPeriodEnd       DateTime
  totalOrdersAnalyzed   Int
  
  seller                Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  @@map("sri_history")
  @@index([sellerId])
  @@index([calculationDate])
}

// ============================================================================
// INVENTORY MANAGEMENT
// ============================================================================

enum Currency {
  USD
  ZWL
}

enum ProductCondition {
  NEW
  USED
  REFURBISHED
}

model SellerInventory {
  id                String   @id @default(uuid())
  sellerId          String
  masterProductId   String
  
  // Pricing
  sellerPrice       Float    // Seller's price in primary currency
  currency          Currency @default(USD)
  
  // Stock
  quantity          Int
  lowStockThreshold Int      @default(5)
  reorderPoint      Int?     // Alert when stock falls below this
  
  // Seller-specific fields
  condition         ProductCondition @default(NEW)
  sellerSku         String?  // Seller's internal SKU
  sellerImages      Json?    // Array of up to 5 image URLs (seller's photos)
  sellerNotes       String?  @db.Text
  
  // Metadata
  isActive          Boolean  @default(true)
  lastPriceUpdate   DateTime?
  priceUpdateCount  Int      @default(0) // For anti-sniping detection
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller            Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  masterProduct     MasterProduct @relation(fields: [masterProductId], references: [id])
  orderItems        OrderItem[]
  adjustmentLogs    InventoryAdjustmentLog[]
  
  @@unique([sellerId, masterProductId])
  @@map("seller_inventory")
  @@index([sellerId])
  @@index([masterProductId])
  @@index([isActive])
  @@index([condition])
}

// ============================================================================
// SELLER ERP MODULE - Inventory Tracking & History
// ============================================================================

model InventoryAdjustmentLog {
  id                  String    @id @default(uuid())
  inventoryId         String
  sellerId            String
  
  // What changed
  adjustmentType      String    // PRICE_CHANGE, STOCK_INCREASE, STOCK_DECREASE, BULK_UPDATE
  
  // Old vs New values
  oldPrice            Float?
  newPrice            Float?
  oldQuantity         Int?
  newQuantity         Int?
  quantityChange      Int?      // +/- amount
  
  // Who made the change
  adjustedBy          String?   // Staff ID or Seller ID
  adjustedByType      String    // SELLER, STAFF
  adjustedByName      String?   // For display
  
  // Why
  reason              String?   @db.Text
  notes               String?   @db.Text
  
  // Metadata
  ipAddress           String?
  userAgent           String?   @db.Text
  
  createdAt           DateTime  @default(now())

  inventory           SellerInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  
  @@map("inventory_adjustment_logs")
  @@index([inventoryId])
  @@index([sellerId, createdAt])
  @@index([adjustmentType])
}

enum BulkUploadStatus {
  PENDING           // Upload received, not processed yet
  PROCESSING        // Currently being processed
  COMPLETED         // Successfully completed
  COMPLETED_WITH_ERRORS // Completed but some rows failed
  FAILED            // Complete failure
}

model BulkUpload {
  id                  String            @id @default(uuid())
  sellerId            String
  
  // Upload details
  fileName            String
  fileUrl             String?           // S3 URL for the uploaded CSV
  fileSize            Int?              // File size in bytes
  totalRows           Int               @default(0)
  
  // Processing results
  status              BulkUploadStatus  @default(PENDING)
  processedRows       Int               @default(0)
  successRows         Int               @default(0)
  failedRows          Int               @default(0)
  
  // Validation report
  validationReport    Json?             // Array of errors/warnings
  errorSummary        String?           @db.Text
  
  // Processing metadata
  startedAt           DateTime?
  completedAt         DateTime?
  processingTime      Int?              // Seconds
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  seller              Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  @@map("bulk_uploads")
  @@index([sellerId, createdAt])
  @@index([status])
}

// ============================================================================
// SELLER ERP MODULE - Accounting & Finance
// ============================================================================

enum TransactionType {
  SALE
  EXPENSE
  COMMISSION
  REFUND
  PAYOUT
  ADJUSTMENT
}

enum ExpenseCategory {
  RENT
  UTILITIES
  WAGES
  FUEL
  MARKETING
  EQUIPMENT
  SUPPLIES
  MAINTENANCE
  INSURANCE
  OTHER
}

// Chart of Accounts
model ChartOfAccount {
  id          String        @id @default(uuid())
  code        String        @unique // e.g., "6110", "4000"
  name        String        // e.g., "Platform Commission", "Sales Revenue"
  type        AccountType   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE, COGS
  parentId    String?       // For hierarchical structure
  isActive    Boolean       @default(true)
  isSystem    Boolean       @default(true) // System accounts can't be deleted by sellers
  description String?       @db.Text
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  parent      ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    ChartOfAccount[] @relation("AccountHierarchy")
  ledgerEntries SellerLedger[]
  
  @@map("chart_of_accounts")
  @@index([type])
  @@index([code])
  @@index([isActive])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COGS
}

model SellerLedger {
  id              String          @id @default(uuid())
  sellerId        String
  accountId       String?         // Link to Chart of Accounts
  transactionDate DateTime
  type            TransactionType
  category        String?
  amountUSD       Float
  amountZWL       Float?
  description     String          @db.Text
  referenceId     String?         // Order ID, Expense ID, Payout ID, etc.
  
  // Double-entry bookkeeping
  debit           Float?
  credit          Float?
  balance         Float           // Running balance
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  seller          Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  account         ChartOfAccount?    @relation(fields: [accountId], references: [id])
  
  @@map("seller_ledger")
  @@index([sellerId, transactionDate])
  @@index([type])
  @@index([referenceId])
  @@index([accountId])
}

model SellerExpense {
  id              String          @id @default(uuid())
  sellerId        String
  date            DateTime
  category        ExpenseCategory
  amount          Float
  currency        Currency        @default(USD)
  description     String          @db.Text
  receiptUrl      String?         // S3 URL for receipt image/PDF
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  seller          Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  @@map("seller_expenses")
  @@index([sellerId, date])
  @@index([category])
}

// ============================================================================
// SELLER ERP MODULE - Staff Management
// ============================================================================

enum StaffRole {
  STOCK_MANAGER    // Can manage inventory
  DISPATCHER       // Can update order status only
  FINANCE_VIEW     // Can view accounting (read-only)
  FULL_ACCESS      // All permissions except delete seller account
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum StaffDepartment {
  SALES
  WAREHOUSE
  DELIVERY
  ADMIN
  SUPPORT
}

enum ActivityType {
  STAFF_CREATED
  STAFF_UPDATED
  STAFF_DEACTIVATED
  STAFF_REACTIVATED
  STAFF_TERMINATED
  TIME_LOGGED
  INVENTORY_UPDATED
  ORDER_UPDATED
  OTHER
}

model SellerStaff {
  id              String          @id @default(uuid())
  sellerId        String
  email           String          @unique
  passwordHash    String          // Hashed with bcrypt
  firstName       String
  lastName        String
  phone           String
  
  // Department & Position
  department      StaffDepartment
  position        String
  
  // Compensation
  salary          Float
  hourlyRate      Float?          // For payroll calculation
  
  // Employment
  startDate       DateTime
  endDate         DateTime?
  
  // Role & Permissions
  role            StaffRole       @default(DISPATCHER)
  
  // Status
  status          StaffStatus     @default(ACTIVE)
  isActive        Boolean         @default(true)
  lastLogin       DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  seller          Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  timeLogs        StaffTimeLog[]
  activityLogs    StaffActivityLog[]
  
  @@map("seller_staff")
  @@index([sellerId])
  @@index([email])
  @@index([isActive])
  @@index([status])
  @@index([department])
}

model StaffTimeLog {
  id              String      @id @default(uuid())
  staffId         String
  sellerId        String
  
  // Time tracking
  clockIn         DateTime
  clockOut        DateTime?
  hoursWorked     Float?      // Calculated when clocked out
  
  // Metadata
  date            DateTime    // Date of shift (for easy querying)
  notes           String?     @db.Text
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  staff           SellerStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  
  @@map("staff_time_logs")
  @@index([staffId, date])
  @@index([sellerId, date])
}

model StaffActivityLog {
  id              String        @id @default(uuid())
  staffId         String
  sellerId        String
  
  // Activity details
  activityType    ActivityType  // Type of activity
  action          String?       // e.g., "UPDATED_ORDER_STATUS", "ADDED_PRODUCT"
  entityType      String?       // e.g., "ORDER", "INVENTORY"
  entityId        String?       // ID of affected entity
  description     String        @db.Text
  metadata        Json?         // Additional data
  
  ipAddress       String?
  userAgent       String?       @db.Text
  
  createdAt       DateTime      @default(now())

  staff           SellerStaff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  
  @@map("staff_activity_logs")
  @@index([staffId])
  @@index([activityType])
  @@index([sellerId, createdAt])
  @@index([entityType, entityId])
}

// ============================================================================
// SELLER ERP MODULE - Loan & Financing
// ============================================================================

enum LoanStatus {
  DRAFT           // Application not yet submitted
  SUBMITTED       // Submitted to partner
  UNDER_REVIEW    // Partner is reviewing
  APPROVED        // Loan approved
  REJECTED        // Application rejected
  DISBURSED       // Funds have been disbursed
  ACTIVE          // Loan is active (being repaid)
  PAID_OFF        // Loan fully paid
  DEFAULTED       // Loan in default
}

model FinancialPartner {
  id              String      @id @default(uuid())
  name            String
  slug            String      @unique
  logo            String?     // Logo URL
  description     String      @db.Text
  
  // Loan terms
  minAmount       Float
  maxAmount       Float
  interestRate    Float       // Annual interest rate (e.g., 0.12 for 12%)
  termMonths      Int         // Loan term in months
  
  // API Integration
  apiEndpoint     String?
  apiKey          String?     // Encrypted
  webhookUrl      String?
  
  // Status
  isActive        Boolean     @default(true)
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  loanApplications LoanApplication[]
  
  @@map("financial_partners")
  @@index([slug])
  @@index([isActive])
}

model LoanApplication {
  id                  String            @id @default(uuid())
  sellerId            String
  partnerId           String
  
  // Application details
  requestedAmount     Float
  currency            Currency          @default(USD)
  purpose             String            @db.Text
  status              LoanStatus        @default(DRAFT)
  
  // Auto-attached seller data (snapshot at time of application)
  last6MonthsRevenue  Float?
  inventoryValue      Float?
  storeHealthScore    Float?            // SRI score at time of application
  monthlyOrderCount   Int?
  
  // Application form data
  businessRevenue     Float?             // Last 12 months revenue
  businessExpenses    Float?             // Last 12 months expenses
  collateralDescription String?          @db.Text
  applicationData     Json?             // Additional form fields
  
  // Partner responses
  partnerReferenceId  String?           // Partner's internal loan ID
  partnerResponse     Json?             // Response from partner API
  rejectionReason     String?           @db.Text
  
  // Loan details (if approved)
  approvedAmount      Float?
  interestRate        Float?
  termMonths          Int?
  monthlyPayment      Float?
  
  // Timestamps
  submittedAt         DateTime?
  reviewedAt          DateTime?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  disbursedAt         DateTime?
  
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  seller              Seller            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  partner             FinancialPartner  @relation(fields: [partnerId], references: [id])
  
  @@map("loan_applications")
  @@index([sellerId, status])
  @@index([partnerId])
  @@index([status])
  @@index([submittedAt])
}

// ============================================================================
// BUYER MANAGEMENT
// ============================================================================

enum BuyerType {
  INDIVIDUAL
  ENTERPRISE
}

enum BuyerStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
}

model Buyer {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String   // Argon2id hashed
  firstName         String
  lastName          String
  phoneNumber       String   // Encrypted
  
  // Buyer type
  buyerType         BuyerType @default(INDIVIDUAL)
  status            BuyerStatus @default(ACTIVE)
  
  // Loyalty program (Individual buyers)
  loyaltyPoints     Int      @default(0)
  loyaltyTier       LoyaltyTier @default(BRONZE)
  
  // Enterprise-specific fields
  companyName       String?
  taxId             String?
  creditLimit       Float?   @default(0)
  creditUsed        Float?   @default(0)
  paymentTermDays   Int?     // e.g., 30 for net-30
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  orders            Order[]
  addresses         BuyerAddress[]
  enterpriseUsers   EnterpriseUser[] // For multi-user management
  integrations      ExternalIntegration[]
  savedSearches      SavedSearch[]
  approvalWorkflows  ApprovalWorkflow[]
  disputes           Dispute[]
  quoteRequests      QuoteRequest[]
  
  @@map("buyers")
  @@index([email])
  @@index([buyerType])
  @@index([status])
}

model BuyerAddress {
  id                String   @id @default(uuid())
  buyerId           String
  
  fullName          String
  phoneNumber       String
  addressLine1      String
  addressLine2      String?
  city              String
  province          String
  postalCode        String?
  
  isDefault         Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  buyer             Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  orders            Order[]
  
  @@map("buyer_addresses")
  @@index([buyerId])
}

enum EnterpriseUserRole {
  MASTER_ADMIN
  REQUESTER
  APPROVER
  VIEWER
}

model EnterpriseUser {
  id                String   @id @default(uuid())
  enterpriseBuyerId String
  email             String   @unique
  firstName         String
  lastName          String
  role              EnterpriseUserRole
  spendingLimit     Float?   // Per-transaction limit
  
  isActive          Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  enterpriseBuyer   Buyer    @relation(fields: [enterpriseBuyerId], references: [id], onDelete: Cascade)
  
  @@map("enterprise_users")
  @@index([enterpriseBuyerId])
  @@index([email])
}

// ============================================================================
// EXTERNAL SYSTEM INTEGRATIONS (PLACEHOLDERS)
// ============================================================================

enum IntegrationType {
  SAGE_PASTEL
  SAP
  CUSTOM_ERP
  VIN_DECODER
  SMS_GATEWAY
  PAYMENT_GATEWAY
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  FAILED
  PENDING_SETUP
}

model ExternalIntegration {
  id                String   @id @default(uuid())
  buyerId           String?  // For buyer-specific integrations
  sellerId          String?  // For seller-specific integrations
  adminId           String?  // For admin/system integrations
  
  integrationType   IntegrationType
  name              String   // e.g., "Company ERP", "VIN Decoder"
  
  // Connection details (encrypted)
  apiEndpoint       String?
  apiKey            String?  // Encrypted
  clientId          String?  // Encrypted
  clientSecret      String?  // Encrypted
  webhookUrl        String?
  
  // Configuration
  config            Json?    // Integration-specific settings
  isActive          Boolean  @default(false)
  status            IntegrationStatus @default(PENDING_SETUP)
  
  // Sync tracking
  lastSyncAt        DateTime?
  syncStatus        String?  // "SUCCESS", "FAILED", "PENDING"
  syncError         String?  @db.Text
  
  // Rate limiting
  rateLimitPerHour  Int?     @default(1000)
  currentRateCount  Int      @default(0)
  rateLimitResetAt  DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  buyer             Buyer?   @relation(fields: [buyerId], references: [id])
  seller            Seller?  @relation(fields: [sellerId], references: [id])
  admin             Admin?   @relation(fields: [adminId], references: [id])
  
  @@map("external_integrations")
  @@index([buyerId])
  @@index([sellerId])
  @@index([integrationType])
  @@index([status])
}

// VIN Decoder integration placeholder
model VinDecodeCache {
  id                String   @id @default(uuid())
  vin               String   @unique
  make              String
  model             String
  year              Int
  engine            String?
  transmission     String?
  bodyStyle         String?
  fuelType          String?
  
  // Confidence score
  confidence        Float    // 0.0 to 1.0
  
  // Cached data
  rawResponse       Json?    // Full API response
  decodedAt         DateTime @default(now())
  expiresAt         DateTime // Cache expiration
  
  @@map("vin_decode_cache")
  @@index([vin])
  @@index([expiresAt])
}

// SMS Gateway integration placeholder
model SmsMessage {
  id                String   @id @default(uuid())
  recipient         String   // Phone number
  message           String   @db.Text
  templateId        String?  // SMS template reference
  
  // Gateway details
  gatewayProvider   String?  // e.g., "Econet", "NetOne"
  gatewayMessageId  String?
  gatewayStatus     String?  // "SENT", "DELIVERED", "FAILED"
  
  // Status tracking
  status            String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt            DateTime?
  deliveredAt       DateTime?
  failedAt          DateTime?
  failureReason     String?  @db.Text
  
  // Retry logic
  retryCount        Int      @default(0)
  maxRetries        Int      @default(3)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("sms_messages")
  @@index([recipient])
  @@index([status])
  @@index([createdAt])
}

// Payment Gateway integration placeholder
model PaymentGatewayTransaction {
  id                String   @id @default(uuid())
  orderId           String
  paymentId         String
  
  // Gateway details
  gatewayProvider   String   // e.g., "Paynow", "Ecocash"
  gatewayTransactionId String @unique
  gatewayResponse   Json?    // Full gateway response
  
  // Amounts
  amount            Float
  currency          Currency
  gatewayFee        Float?
  
  // Status
  status            String   // PENDING, COMPLETED, FAILED, REFUNDED
  processedAt       DateTime?
  failedAt          DateTime?
  failureReason     String?  @db.Text
  
  // Webhook tracking
  webhookReceived   Boolean  @default(false)
  webhookData       Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  order             Order    @relation(fields: [orderId], references: [id])
  payment           Payment  @relation(fields: [paymentId], references: [id])
  
  @@map("payment_gateway_transactions")
  @@index([orderId])
  @@index([gatewayTransactionId])
  @@index([status])
}

// ============================================================================
// BUYER FEATURES
// ============================================================================

model SavedSearch {
  id                String   @id @default(uuid())
  buyerId           String
  name              String
  description       String?  @db.Text
  criteria          Json     // Search criteria object
  isPublic          Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  buyer             Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  
  @@map("saved_searches")
  @@index([buyerId])
  @@index([isPublic])
}

model ApprovalWorkflow {
  id                String   @id @default(uuid())
  enterpriseBuyerId String
  name              String
  description       String?  @db.Text
  conditions        Json     // Approval conditions
  approvers         Json     // Array of approver user IDs
  isActive          Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  enterpriseBuyer   Buyer    @relation(fields: [enterpriseBuyerId], references: [id], onDelete: Cascade)
  
  @@map("approval_workflows")
  @@index([enterpriseBuyerId])
  @@index([isActive])
}


// ============================================================================
// QUOTE REQUEST SYSTEM
// ============================================================================

model QuoteRequest {
  id                    String   @id @default(uuid())
  productId             String
  buyerId               String
  sellerId              String
  quantity              Int
  message               String?  @db.Text
  urgency               String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  expectedDeliveryDate  DateTime?
  status                String   @default("PENDING") // PENDING, RESPONDED, ACCEPTED, REJECTED, EXPIRED
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  product               MasterProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer                 Buyer         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  seller                Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  quote                 QuoteResponse?
  
  @@map("quote_requests")
  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
  @@index([status])
}

model QuoteResponse {
  id                    String   @id @default(uuid())
  quoteRequestId        String   @unique
  sellerId              String
  price                 Float
  availability           String   // IN_STOCK, OUT_OF_STOCK, BACKORDER
  estimatedDelivery      DateTime?
  message                String?  @db.Text
  validUntil            DateTime?
  status                 String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, EXPIRED
  
  respondedAt            DateTime @default(now())
  updatedAt              DateTime @updatedAt

  quoteRequest          QuoteRequest @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  seller                Seller       @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  
  @@map("quote_responses")
  @@index([quoteRequestId])
  @@index([sellerId])
  @@index([status])
}

// ============================================================================
// ORDERS & TRANSACTIONS
// ============================================================================

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  AWAITING_SELLER_ACCEPTANCE
  SELLER_REJECTED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  DISPUTED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  ECOCASH
  PAYNOW
  BANK_TRANSFER
  CREDIT_FACILITY
  CASH_ON_DELIVERY
}

model Order {
  id                    String   @id @default(uuid())
  orderNumber           String   @unique // Human-readable order number
  buyerId               String
  sellerId              String
  addressId             String
  
  // Enterprise-specific
  poNumber              String?  // Purchase Order Number
  costCenter            String?  // Cost center reference
  
  // Pricing
  subtotal              Float
  shippingCost          Float
  platformCommission    Float
  totalAmount           Float    // Display price (Pdisplay)
  currency              Currency
  exchangeRate          Float?   // Locked exchange rate for ZWL transactions
  exchangeRateTimestamp DateTime?
  
  // Status
  status                OrderStatus @default(PENDING_PAYMENT)
  paymentStatus         PaymentStatus @default(PENDING)
  
  // Fulfilment
  sellerAcceptedAt      DateTime?
  sellerRejectedAt      DateTime?
  rejectionReason       String?  @db.Text
  
  // Shipping
  estimatedDeliveryDate DateTime?
  actualDeliveryDate    DateTime?
  
  // Metadata
  ipAddress             String?
  userAgent             String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  buyer                 Buyer         @relation(fields: [buyerId], references: [id])
  seller                Seller        @relation(fields: [sellerId], references: [id])
  shippingAddress       BuyerAddress  @relation(fields: [addressId], references: [id])
  items                 OrderItem[]
  payment               Payment?
  shipment              Shipment?
  disputes              Dispute[]
  payout                Payout?
  gatewayTransactions    PaymentGatewayTransaction[]
  
  @@map("orders")
  @@index([buyerId])
  @@index([sellerId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  inventoryId       String
  
  quantity          Int
  unitPrice         Float    // Seller price at time of order
  displayPrice      Float    // Display price (with commission)
  commission        Float    // Platform commission
  
  createdAt         DateTime @default(now())

  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  inventory         SellerInventory  @relation(fields: [inventoryId], references: [id])
  
  @@map("order_items")
  @@index([orderId])
}

model Payment {
  id                String   @id @default(uuid())
  orderId           String   @unique
  
  amount            Float
  currency          Currency
  paymentMethod     PaymentMethod
  
  // Gateway details
  gatewayProvider   String?  // e.g., "Paynow", "Ecocash"
  gatewayTransactionId String?
  gatewayResponse   Json?
  
  // Status
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  failedAt          DateTime?
  failureReason     String?  @db.Text
  refundedAt        DateTime?
  refundAmount      Float?
  
  // Metadata for chargebacks, refunds, etc.
  metadata          Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  gatewayTransactions PaymentGatewayTransaction[]
  
  @@map("payments")
  @@index([orderId])
  @@index([status])
  @@index([gatewayTransactionId])
}

// ============================================================================
// FINANCIAL MANAGEMENT
// ============================================================================

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  FROZEN
}

model Payout {
  id                String   @id @default(uuid())
  sellerId          String
  orderId           String   @unique
  
  grossAmount       Float    // Seller's price
  platformCommission Float
  gatewayFee        Float
  netAmount         Float    // Amount paid to seller
  currency          Currency
  
  status            PayoutStatus @default(PENDING)
  scheduledDate     DateTime
  processedDate     DateTime?
  
  // Banking details
  bankReference     String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller            Seller   @relation(fields: [sellerId], references: [id])
  order             Order    @relation(fields: [orderId], references: [id])
  
  @@map("payouts")
  @@index([sellerId])
  @@index([status])
  @@index([scheduledDate])
}

model ExchangeRate {
  id                String   @id @default(uuid())
  fromCurrency      Currency
  toCurrency        Currency
  rate              Float
  source            String   // e.g., "RBZ_OFFICIAL", "MANUAL_ADMIN"
  
  effectiveDate     DateTime @default(now())
  createdAt         DateTime @default(now())
  
  @@map("exchange_rates")
  @@index([fromCurrency, toCurrency, effectiveDate])
}

// ============================================================================
// DISPUTE MANAGEMENT
// ============================================================================

enum DisputeType {
  WRONG_PART
  DEFECTIVE_PRODUCT
  COUNTERFEIT_PRODUCT
  NOT_RECEIVED
  DAMAGED_IN_TRANSIT
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_EVIDENCE
  RESOLVED_BUYER_FAVOR
  RESOLVED_SELLER_FAVOR
  CLOSED_NO_FAULT
}

model Dispute {
  id                String   @id @default(uuid())
  orderId           String   @unique
  buyerId           String
  sellerId          String
  disputeType       DisputeType
  status            DisputeStatus @default(OPEN)
  
  // Details
  buyerDescription  String   @db.Text
  sellerResponse    String?  @db.Text
  adminNotes        String?  @db.Text
  
  // Assignment
  assignedAdminId   String?
  
  // Evidence
  buyerEvidenceUrls Json?    // Array of file URLs
  sellerEvidenceUrls Json?   // Array of file URLs
  
  // Resolution
  resolutionDate    DateTime?
  resolutionOutcome String?  @db.Text
  isFaultBased      Boolean  @default(true) // Impacts SRI
  
  // SLO Tracking (Service Level Objective)
  sloTargetDate     DateTime? // Target resolution date based on priority
  sloStatus         String?   // "ON_TIME", "AT_RISK", "BREACHED"
  sloBreached       Boolean   @default(false)
  
  // Metadata for return labels, etc.
  metadata          Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order             Order    @relation(fields: [orderId], references: [id])
  buyer             Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  seller            Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  assignedAdmin     Admin?   @relation(fields: [assignedAdminId], references: [id])
  
  @@map("disputes")
  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([assignedAdminId])
  @@index([createdAt])
  @@index([isFaultBased])
  @@index([sloStatus])
  @@index([sloBreached])
}

// ============================================================================
// LOGISTICS & SHIPPING
// ============================================================================

enum CarrierStatus {
  ACTIVE
  INACTIVE
}

model Carrier {
  id                String   @id @default(uuid())
  name              String   @unique
  code              String   @unique // e.g., "DHL", "FEDEX", "ARAMEX"
  contactEmail      String
  contactPhone      String
  
  // API integration
  hasApiIntegration Boolean  @default(false)
  apiEndpoint       String?
  apiKey            String?  // Encrypted
  
  // Service levels
  serviceLevels     Json     // Array of {name, avgDeliveryDays, costMatrix}
  
  status            CarrierStatus @default(ACTIVE)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  shipments         Shipment[]
  
  @@map("carriers")
  @@index([code])
}

enum ShipmentStatus {
  PENDING_PICKUP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED_DELIVERY
  RETURNED_TO_SENDER
}

model Shipment {
  id                String   @id @default(uuid())
  orderId           String   @unique
  carrierId         String
  
  trackingNumber    String   @unique
  
  // Dimensions and weight (from master product)
  weight            Float
  length            Float
  width             Float
  height            Float
  
  // Status
  status            ShipmentStatus @default(PENDING_PICKUP)
  
  // Tracking
  estimatedDelivery DateTime
  actualDelivery    DateTime?
  trackingHistory   Json?    // Array of {status, timestamp, location, notes}
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier           Carrier  @relation(fields: [carrierId], references: [id])
  
  @@map("shipments")
  @@index([orderId])
  @@index([trackingNumber])
  @@index([status])
}

// ============================================================================
// SELLER HR & PAYROLL
// ============================================================================

model SellerEmployee {
  id                String   @id @default(uuid())
  sellerId          String
  
  nationalId        String   @unique // For tax reconciliation
  firstName         String
  lastName          String
  phoneNumber       String   // Encrypted
  email             String?
  
  // Employment
  position          String
  department        String?
  salary            Float    // Encrypted
  hourlyRate        Float?   // Encrypted
  
  // Banking
  bankAccountNumber String?  // Encrypted
  bankName          String?
  
  isActive          Boolean  @default(true)
  hiredDate         DateTime
  terminatedDate    DateTime?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seller            Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  shifts            EmployeeShift[]
  payslips          Payslip[]
  
  @@map("seller_employees")
  @@index([sellerId])
  @@index([nationalId])
}

model EmployeeShift {
  id                String   @id @default(uuid())
  employeeId        String
  
  clockInTime       DateTime
  clockInLocation   Json     // {lat, lng, accuracy}
  clockOutTime      DateTime?
  clockOutLocation  Json?    // {lat, lng, accuracy}
  
  totalHours        Float?
  isValidated       Boolean  @default(false) // Geo-fence validation
  
  createdAt         DateTime @default(now())

  employee          SellerEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@map("employee_shifts")
  @@index([employeeId])
  @@index([clockInTime])
}

model Payslip {
  id                String   @id @default(uuid())
  employeeId        String
  
  periodStart       DateTime
  periodEnd         DateTime
  
  grossSalary       Float
  payeDeduction     Float    // PAYE tax
  nssaDeduction     Float    // NSSA contribution
  otherDeductions   Float?
  netSalary         Float
  
  pdfUrl            String?  // Signed PDF
  
  generatedAt       DateTime @default(now())
  paidAt            DateTime?
  
  employee          SellerEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  @@map("payslips")
  @@index([employeeId])
  @@index([periodEnd])
}

// ============================================================================
// ADMIN DASHBOARD & ALERTS
// ============================================================================

enum AlertTier {
  CRITICAL  // Tier 1 - Red
  HIGH      // Tier 2 - Orange
  LOW       // Tier 3 - Yellow
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

model AdminAlert {
  id                String   @id @default(uuid())
  tier              AlertTier
  status            AlertStatus @default(OPEN)
  
  title             String
  message           String   @db.Text
  alertCode         String   // e.g., "PAYMENT_GATEWAY_DOWN", "SRI_VIOLATION"
  
  // Context
  entityType        String?  // e.g., "Seller", "Order"
  entityId          String?
  metadata          Json?
  
  // Assignment
  assignedAdminId   String?
  acknowledgedAt    DateTime?
  resolvedAt        DateTime?
  resolutionNotes   String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignedAdmin     Admin?   @relation(fields: [assignedAdminId], references: [id])
  
  @@map("admin_alerts")
  @@index([tier])
  @@index([status])
  @@index([alertCode])
  @@index([createdAt])
}

// ============================================================================
// CUSTOM PRODUCT REQUESTS
// ============================================================================

enum CustomProductRequestStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO_NEEDED
}

model CustomProductRequest {
  id                  String                      @id @default(uuid())
  sellerId            String
  seller              Seller                      @relation(fields: [sellerId], references: [id])
  
  productName         String
  category            String
  make                String
  model               String
  year                Int?
  partCode            String?
  description         String?                     @db.Text
  imageUrls           Json?                       // Array of image URLs
  
  status              CustomProductRequestStatus  @default(PENDING)
  adminNotes          String?                     @db.Text
  reviewedBy          String?                     // Admin ID
  reviewedAt          DateTime?
  
  // If approved, reference to created MasterProduct
  createdProductId    String?                     @unique
  createdProduct      MasterProduct?              @relation(fields: [createdProductId], references: [id])
  
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  
  @@map("custom_product_requests")
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// SYSTEM CONFIGURATION
// ============================================================================

model SystemSetting {
  id                String   @id @default(uuid())
  key               String   @unique
  value             String   @db.Text
  dataType          String   // e.g., "string", "number", "boolean", "json"
  description       String?  @db.Text
  
  updatedBy         String?  // Admin ID
  updatedAt         DateTime @updatedAt
  
  @@map("system_settings")
}
