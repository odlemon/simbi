model Dispute {
  id                      String                  @id @default(uuid())
  orderId                 String                  @unique
  disputeType             DisputeType
  requestType             ReturnRequestType?      // RETURN, EXCHANGE, or DISPUTE
  returnReason            ReturnReason?           // For return/exchange requests
  status                  DisputeStatus           @default(OPEN)
  buyerDescription        String                  @db.Text
  sellerResponse          String?                 @db.Text
  adminNotes              String?                @db.Text
  assignedAdminId         String?
  buyerEvidenceUrls       Json?
  sellerEvidenceUrls      Json?
  eccBaseline             Json?                   // Pre-shipment evidence (Evidence Chain of Custody)
  resolutionDate          DateTime?
  resolutionOutcome       String?                 @db.Text
  isFaultBased            Boolean                 @default(true)
  faultClassification     FaultClassification?   // SELLER_FAULT, BUYER_FAULT, NO_FAULT, LOGISTICS_FAULT
  sloTargetDate           DateTime?
  sloStatus               String?
  sloBreached             Boolean                 @default(false)
  // Return/Exchange specific fields
  returnLabelTrackingNumber String?
  returnLabelUrl          String?
  returnLogisticsCost     Float?
  logisticsCostChargedTo  LogisticsCostChargedTo?
  exchangeOrderId         String?                 // For exchange fulfillment
  sellerReceiptConfirmed  Boolean                 @default(false)
  sellerReceiptConfirmedAt DateTime?
  inspectionCompletedAt  DateTime?
  // Tier 1 Reroute fields
  tier1RerouteTriggered   Boolean                 @default(false)
  tier1RerouteSellerId   String?
  tier1RerouteCostDifference Float?
  metadata                Json?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  buyerId                 String
  sellerId                String
  assignedAdmin           Admin?                  @relation(fields: [assignedAdminId], references: [id])
  buyer                   Buyer                   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  order                   Order                   @relation(fields: [orderId], references: [id])
  seller                  Seller                  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  buyerNotifications      BuyerNotification[]      @relation
  sellerNotifications     SellerNotification[]     @relation("SellerNotificationDispute")

  @@index([orderId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@index([assignedAdminId])
  @@index([createdAt])
  @@index([isFaultBased])
  @@index([sloStatus])
  @@index([sloBreached])
  @@index([faultClassification])
  @@index([requestType])
  @@map("disputes")
}

model Carrier {
  id                String        @id @default(uuid())
  name              String        @unique
  code              String        @unique
  contactEmail      String
  contactPhone      String
  hasApiIntegration Boolean       @default(false)
  apiEndpoint       String?
  apiKey            String?
  serviceLevels     Json
  status            CarrierStatus @default(ACTIVE)
  /// Non-secret: rateQuotePath, trackingPollPath, method, header templates (loan-style).
  integrationConfigJson   Json?
  /// Secrets: apiKey, webhookSigningSecret — never returned in list APIs.
  integrationSecretsJson  Json?
  /// SLA JSON: pickupSlaHours, deliverySlaByTier { SMALL, MEDIUM, LARGE }.
  slaConfigJson             Json?
  supportsWebhook           Boolean @default(true)
  pollingIntervalMinutes    Int     @default(30)
  displayPriority             Int     @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
