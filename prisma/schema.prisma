model ComplianceAudit {
  id        String   @id @default(uuid())
  sellerId  String
  score     Int
  notes     String?  @db.Text
  auditedBy String
  createdAt DateTime @default(now())

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([sellerId, createdAt])
  @@map("compliance_audits")
}

model CustomProductRequest {
  id               String                     @id @default(uuid())
  sellerId         String
  productName      String
  category         String
  make             String
  model            String
  year             Int?
  partCode         String?
  description      String?                    @db.Text
  imageUrls        Json?
  /// URL of the OEM specification sheet (PDF) — required on new submissions
  specSheetUrl     String?                    @db.Text
  /// Supplier documentation for mandatory counterfeit check (array of PDF URLs)
  supplierDocUrls  Json?
  /// Admin must approve/reject within 72h of submission (SLO)
  reviewDueAt      DateTime?
  counterfeitCheckVerified   Boolean   @default(false)
  counterfeitCheckVerifiedAt DateTime?
  counterfeitCheckVerifiedBy String?
  counterfeitCheckNotes      String?   @db.Text
  status           CustomProductRequestStatus @default(PENDING)
  adminNotes       String?                    @db.Text
  reviewedBy       String?
  reviewedAt       DateTime?
  createdProductId String?                    @unique
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  createdProduct   MasterProduct?             @relation(fields: [createdProductId], references: [id])
  seller           Seller                     @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([reviewDueAt])
  @@index([status, reviewDueAt])
  @@map("custom_product_requests")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  dataType    String
  description String?  @db.Text
  updatedBy   String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

model Coupon {
  id                  String        @id @default(uuid())
  code                String        @unique
  name                String
  description         String?       @db.Text
  discountType        DiscountType
  discountValue       Float         // Percentage (0-100) or fixed amount
  minimumOrderAmount  Float?        // Minimum order amount to use coupon
  maximumDiscount     Float?        // Maximum discount amount (for percentage coupons)
  couponType          CouponType    @default(PLATFORM_WIDE)
  sellerId            String?       // If seller-specific, which seller
  applicableCategories Json?        // Array of category IDs (if product-specific)
  applicableProducts   Json?        // Array of product IDs (if product-specific)
  isActive            Boolean       @default(true)
  usageLimit          Int?         // Total usage limit (null = unlimited)
  usageCount          Int           @default(0)
  userUsageLimit      Int?         // Per-user usage limit (null = unlimited)
  validFrom           DateTime      @default(now())
  validUntil          DateTime
  createdBy           String        // Admin ID or Seller ID
  createdByType       String        // 'admin' or 'seller'
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  usages              CouponUsage[]
  seller              Seller?       @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([sellerId])
  @@index([isActive])
  @@index([validUntil])
  @@index([couponType])
  @@map("coupons")
}

model CouponUsage {
  id          String   @id @default(uuid())
  couponId    String
  orderId     String   @unique
  buyerId     String
  discountAmount Float
  orderTotal  Float    // Order total before discount
  orderTotalAfterDiscount Float // Order total after discount
  usedAt      DateTime @default(now())
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer       Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([buyerId])
  @@index([orderId])
  @@index([usedAt])
  @@map("coupon_usages")
}

model FailedLoginAttempt {
  id            String    @id @default(uuid())
  email         String?
  ipAddress     String
  userType      String    // 'admin', 'seller', 'buyer', 'staff'
  accountExists Boolean   @default(false)
  createdAt     DateTime  @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([userType])
  @@index([createdAt])
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("failed_login_attempts")
}

