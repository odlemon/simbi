generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                    String                @id @default(uuid())
  email                 String                @unique
  password              String
  firstName             String
  lastName              String
  role                  UserRole
  status                UserStatus            @default(ACTIVE)
  mfaEnabled            Boolean               @default(false)
  mfaSecret             String?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  failedLoginAttempts   Int                   @default(0)
  accountLockedUntil    DateTime?
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  activityLogs          ActivityLog[]
  alertsHandled         AdminAlert[]
  disputesHandled       Dispute[]
  integrations          ExternalIntegration[]
  reviewModerations     ReviewModeration[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("admins")
}

model ActivityLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  entityType String
  entityId   String
  ipAddress  String
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())
  admin      Admin    @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model MasterProduct {
  id                   String                @id @default(uuid())
  masterPartId         String                @unique
  oemPartNumber        String
  name                 String
  description          String                @db.Text
  categoryId           String
  manufacturer         String
  length               Float?
  width                Float?
  height               Float?
  weight               Float?
  unit                 MeasurementUnit       @default(METRIC)
  vehicleCompatibility Json
  imageUrls            Json?
  specSheetUrl         String?
  isActive             Boolean               @default(true)
  isCustom             Boolean               @default(false)
  approvedAt           DateTime?
  approvedBy           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customRequest        CustomProductRequest?
  category             ProductCategory       @relation(fields: [categoryId], references: [id])
  quoteRequests        QuoteRequest[]
  sellerInventory      SellerInventory[]

  @@index([oemPartNumber])
  @@index([categoryId])
  @@index([manufacturer])
  @@index([isActive])
  @@map("master_products")
}

model ProductCategory {
  id             String            @id @default(uuid())
  name           String            @unique
  slug           String            @unique
  description    String?           @db.Text
  commissionRate Float
  parentId       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  products       MasterProduct[]
  parent         ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       ProductCategory[] @relation("CategoryHierarchy")

  @@index([slug])
  @@index([parentId])
  @@map("product_categories")
}

model Seller {
  id                        String                 @id @default(uuid())
  email                     String                 @unique
  password                  String
  businessName              String
  tradingName               String?
  businessAddress           String                 @db.Text
  contactNumber             String
  tin                       String                 @unique
  registrationNumber        String?
  bankAccountName           String?
  bankAccountNumber         String?
  bankName                  String?
  status                    SellerStatus           @default(ACTIVE)
  sriScore                  Float                  @default(70)
  lastSriCalculation        DateTime?
  mfaEnabled                Boolean                @default(false)
  mfaSecret                 String?
  isEligible                Boolean                @default(true)
  isShadowBanned            Boolean                @default(false)
  failedLoginAttempts       Int                    @default(0)
  accountLockedUntil        DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  emailVerified             Boolean                @default(false)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  passwordResetToken        String?
  passwordResetExpires      DateTime?
  bulkUploads               BulkUpload[]
  customProductRequests     CustomProductRequest[]
  disputes                  Dispute[]
  integrations              ExternalIntegration[]
  loanApplications          LoanApplication[]
  orders                    Order[]
  payouts                   Payout[]
  quoteRequests             QuoteRequest[]
  quoteResponses            QuoteResponse[]
  documents                 SellerDocument[]
  employees                 SellerEmployee[]
  expenses                  SellerExpense[]
  inventory                 SellerInventory[]
  ledgerEntries             SellerLedger[]
  staff                     SellerStaff[]
  sriHistory                SRIHistory[]
  coupons                   Coupon[]
  reviewResponses           ReviewResponse[]
  payrollRuns               PayrollRun[]
  notifications             SellerNotification[]
  complianceAudits          ComplianceAudit[]

  @@index([email])
  @@index([status])
  @@index([sriScore])
  @@index([isEligible])
  @@map("sellers")
}

model SellerDocument {
  id              String         @id @default(uuid())
  sellerId        String
  documentType    DocumentType
  status          DocumentStatus @default(PENDING)
  fileUrl         String
  fileHash        String
  issuedDate      DateTime?
  expiryDate      DateTime?
  uploadedAt      DateTime       @default(now())
  approvedAt      DateTime?
  approvedBy      String?
  rejectionReason String?        @db.Text
  viewLogs        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  seller          Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([documentType])
  @@index([status])
  @@index([expiryDate])
  @@map("seller_documents")
}

model SRIHistory {
  id                  String   @id @default(uuid())
  sellerId            String
  score               Float
  fulfilmentRate      Float
  onTimeDeliveryRate  Float
  defectRate          Float
  complianceScore     Float
  calculationDate     DateTime @default(now())
  ordersPeriodStart   DateTime
  ordersPeriodEnd     DateTime
  totalOrdersAnalyzed Int
  seller              Seller   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([calculationDate])
  @@map("sri_history")
}

model SellerInventory {
  id                String                   @id @default(uuid())
  sellerId          String
  masterProductId   String
  sellerPrice       Float
  currency          Currency                 @default(USD)
  quantity          Int
  lowStockThreshold Int                      @default(5)
  isActive          Boolean                  @default(true)
  lastPriceUpdate   DateTime?
  priceUpdateCount  Int                      @default(0)
  averageRating     Float?                  @default(0) // Average rating from reviews
  reviewCount       Int                      @default(0) // Total number of approved reviews
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  condition         ProductCondition         @default(NEW)
  reorderPoint      Int?
  sellerImages      Json?
  sellerNotes       String?                  @db.Text
  sellerSku         String?
  cartItems         CartItem[]
  adjustmentLogs    InventoryAdjustmentLog[]
  orderItems        OrderItem[]
  reviews           Review[]
  masterProduct     MasterProduct            @relation(fields: [masterProductId], references: [id])
  seller            Seller                   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, masterProductId])
  @@index([sellerId])
  @@index([masterProductId])
  @@index([isActive])
  @@index([condition])
  @@map("seller_inventory")
}

model InventoryAdjustmentLog {
  id             String          @id @default(uuid())
  inventoryId    String
  sellerId       String
  adjustmentType String
  oldPrice       Float?
  newPrice       Float?
  oldQuantity    Int?
  newQuantity    Int?
  quantityChange Int?
  adjustedBy     String?
  adjustedByType String
  adjustedByName String?
  reason         String?         @db.Text
  notes          String?         @db.Text
  ipAddress      String?
  userAgent      String?         @db.Text
  createdAt      DateTime        @default(now())
  inventory      SellerInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([sellerId, createdAt])
  @@index([adjustmentType])
  @@map("inventory_adjustment_logs")
}

model BulkUpload {
  id               String           @id @default(uuid())
  sellerId         String
  fileName         String
  fileUrl          String?
  fileSize         Int?
  totalRows        Int              @default(0)
  status           BulkUploadStatus @default(PENDING)
  processedRows    Int              @default(0)
  successRows      Int              @default(0)
  failedRows       Int              @default(0)
  validationReport Json?
  errorSummary     String?          @db.Text
  startedAt        DateTime?
  completedAt      DateTime?
  processingTime   Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  seller           Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
  @@index([status])
  @@map("bulk_uploads")
}

model ChartOfAccount {
  id            String           @id @default(uuid())
  code          String           @unique
  name          String
  type          AccountType
  parentId      String?
  isActive      Boolean          @default(true)
  isSystem      Boolean          @default(true)
  description   String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  parent        ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children      ChartOfAccount[] @relation("AccountHierarchy")
  ledgerEntries SellerLedger[]

  @@index([type])
  @@index([code])
  @@index([isActive])
  @@index([parentId], map: "chart_of_accounts_parentId_fkey")
  @@map("chart_of_accounts")
}

model SellerLedger {
  id              String          @id @default(uuid())
  sellerId        String
  transactionDate DateTime
  type            TransactionType
  category        String?
  amountUSD       Float
  amountZWL       Float?
  description     String          @db.Text
  referenceId     String?
  debit           Float?
  credit          Float?
  balance         Float
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  accountId       String?
  account         ChartOfAccount? @relation(fields: [accountId], references: [id])
  seller          Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, transactionDate])
  @@index([type])
  @@index([referenceId])
  @@index([accountId])
  @@map("seller_ledger")
}

model SellerExpense {
  id          String          @id @default(uuid())
  sellerId    String
  date        DateTime
  category    ExpenseCategory
  amount      Float
  currency    Currency        @default(USD)
  description String          @db.Text
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  seller      Seller          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, date])
  @@index([category])
  @@map("seller_expenses")
}

model SellerStaff {
  id                  String             @id @default(uuid())
  sellerId            String
  email               String             @unique
  firstName           String
  lastName            String
  phone               String
  role                StaffRole          @default(DISPATCHER)
  hourlyRate          Float?
  isActive            Boolean            @default(true)
  lastLogin           DateTime?
  failedLoginAttempts Int                @default(0)
  accountLockedUntil   DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  department          StaffDepartment
  endDate             DateTime?
  passwordHash        String
  position            String
  salary              Float
  startDate           DateTime
  status              StaffStatus        @default(ACTIVE)
  passwordResetToken  String?
  passwordResetExpires DateTime?
  seller              Seller             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  activityLogs        StaffActivityLog[]
  timeLogs            StaffTimeLog[]
  payslips            StaffPayslip[]
  notifications       SellerNotification[]

  @@index([sellerId])
  @@index([email])
  @@index([isActive])
  @@index([status])
  @@index([department])
  @@map("seller_staff")
}

model StaffTimeLog {
  id          String      @id @default(uuid())
  staffId     String
  sellerId    String
  clockIn     DateTime
  clockOut    DateTime?
  hoursWorked Float?
  date        DateTime
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  staff       SellerStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId, date])
  @@index([sellerId, date])
  @@map("staff_time_logs")
}

model StaffActivityLog {
  id           String       @id @default(uuid())
  staffId      String
  sellerId     String
  action       String?
  entityType   String?
  entityId     String?
  description  String       @db.Text
  metadata     Json?
  ipAddress    String?
  userAgent    String?      @db.Text
  createdAt    DateTime     @default(now())
  activityType ActivityType
  staff        SellerStaff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([activityType])
  @@index([sellerId, createdAt])
  @@index([entityType, entityId])
  @@map("staff_activity_logs")
}

model PayrollRun {
  id              String         @id @default(uuid())
  sellerId        String
  period          String         // "weekly" or "monthly"
  periodStart     DateTime
  periodEnd       DateTime
  month           Int?
  year            Int?
  weekStart       DateTime?
  totalAmount     Float
  staffCount      Int
  payslipsCount   Int
  status          PayrollStatus  @default(PENDING)
  processedAt     DateTime?
  processedBy     String?        // Seller ID who processed it
  notes           String?         @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  seller          Seller         @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  payslips        StaffPayslip[]

  @@index([sellerId])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([createdAt])
  @@map("payroll_runs")
}

model StaffPayslip {
  id              String      @id @default(uuid())
  staffId         String
  sellerId        String
  payrollRunId    String
  periodStart     DateTime
  periodEnd       DateTime
  grossPay        Float
  totalHours      Float?
  hourlyPay       Float?
  salaryForPeriod Float
  netPay          Float       // Same as grossPay for now (no deductions)
  emailSent       Boolean     @default(false)
  emailSentAt     DateTime?
  pdfUrl          String?
  generatedAt     DateTime    @default(now())
  paidAt          DateTime?
  staff           SellerStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  payrollRun      PayrollRun  @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([sellerId])
  @@index([payrollRunId])
  @@index([periodStart, periodEnd])
  @@index([generatedAt])
  @@map("staff_payslips")
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
  CANCELLED
}

model FinancialPartner {
  id                      String            @id @default(uuid())
  name                    String
  slug                    String            @unique
  logo                    String?
  description             String            @db.Text
  minAmount               Float
  maxAmount               Float
  interestRate            Float
  termMonths              Int
  apiEndpoint             String?
  apiKey                  String?
  webhookUrl              String?
  contactEmail            String?
  feesAndTermsSummary     String?           @db.Text
  /** Seller-facing extra form fields: [{ key, label, type, required }] */
  fieldDefinitionsJson    Json?
  /** Non-secret integration: baseUrl, submitPath, statusPath, authType, header templates, bodyFieldMapping */
  integrationConfigJson   Json?
  /** Secrets (API keys, webhook HMAC secret). Never exposed to sellers; mask in admin list. */
  integrationSecretsJson  Json?
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  loanApplications        LoanApplication[]

  @@index([slug])
  @@index([isActive])
  @@map("financial_partners")
}

model LoanApplication {
  id                    String           @id @default(uuid())
  sellerId              String
  partnerId             String
  requestedAmount       Float
  currency              Currency         @default(USD)
  purpose               String           @db.Text
  status                LoanStatus       @default(DRAFT)
  last6MonthsRevenue    Float?
  inventoryValue        Float?
  storeHealthScore      Float?
  monthlyOrderCount     Int?
  applicationData       Json?
  /** Server-computed bundle sent to partner (revenue, inventory, SRI, etc.) */
  verifiedSnapshot      Json?
  partnerReferenceId    String?
  partnerResponse       Json?
  rejectionReason       String?          @db.Text
  approvedAmount        Float?
  interestRate          Float?
  termMonths            Int?
  monthlyPayment        Float?
  submittedAt           DateTime?
  reviewedAt            DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  disbursedAt           DateTime?
  lastStatusSyncAt      DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  businessExpenses      Float?
  businessRevenue       Float?
  collateralDescription String?          @db.Text
  partner               FinancialPartner @relation(fields: [partnerId], references: [id])
  seller                Seller           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  statusEvents          LoanApplicationStatusEvent[]

  @@index([sellerId, status])
  @@index([partnerId])
  @@index([status])
  @@index([submittedAt])
  @@map("loan_applications")
}

model LoanApplicationStatusEvent {
  id                String          @id @default(uuid())
  loanApplicationId String
  fromStatus        LoanStatus?
  toStatus          LoanStatus
  source            String
  note              String?         @db.Text
  rawPayload        Json?
  createdAt         DateTime        @default(now())
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)

  @@index([loanApplicationId])
  @@index([createdAt])
  @@map("loan_application_status_events")
}

model Buyer {
  id                        String                @id @default(uuid())
  email                     String                @unique
  password                  String
  firstName                 String
  lastName                  String
  phoneNumber               String
  buyerType                 BuyerType             @default(INDIVIDUAL)
  status                    BuyerStatus           @default(ACTIVE)
  loyaltyPoints             Int                   @default(0)
  loyaltyTier               LoyaltyTier           @default(BRONZE)
  companyName               String?
  taxId                     String?
  creditLimit               Float?                @default(0)
  creditUsed                Float?                @default(0)
  paymentTermDays           Int?
  failedLoginAttempts       Int                   @default(0)
  accountLockedUntil        DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  couponUsages              CouponUsage[]
  addressLine1              String?
  addressLine2              String?
  billingAddress            String?
  businessType              String?
  city                      String?
  contactEmail              String?
  contactPhone              String?
  country                   String?
  currency                  String?               @default("USD")
  description               String?
  establishedYear           Int?
  industry                  String?
  marketingConsent          Boolean?              @default(false)
  monthlySpendingLimit      Float?
  numberOfEmployees         Int?
  postalCode                String?
  preferredContactMethod    String?
  province                  String?
  registrationNumber        String?
  shippingAddress           String?
  termsAccepted             Boolean?              @default(false)
  website                   String?
  emailVerified             Boolean               @default(false)
  verificationCode          String?
  verificationCodeExpiresAt DateTime?
  passwordResetToken        String?
  passwordResetExpires      DateTime?
  approvalWorkflows         ApprovalWorkflow[]
  addresses                 BuyerAddress[]
  cart                      Cart?
  disputes                  Dispute[]
  enterpriseUsers           EnterpriseUser[]
  integrations              ExternalIntegration[]
  orders                    Order[]
  quoteRequests             QuoteRequest[]
  savedSearches             SavedSearch[]
  reviews                   Review[]
  notifications              BuyerNotification[]

  @@index([email])
  @@index([buyerType])
  @@index([status])
  @@map("buyers")
}

model BuyerAddress {
  id           String   @id @default(uuid())
  buyerId      String
  fullName     String
  phoneNumber  String
  addressLine1 String
  addressLine2 String?
  city         String
  province     String
  postalCode   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  buyer        Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([buyerId])
  @@map("buyer_addresses")
}

model Cart {
  id        String     @id @default(uuid())
  buyerId   String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  buyer     Buyer      @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@map("carts")
}

model CartItem {
  id          String          @id @default(uuid())
  cartId      String
  inventoryId String
  quantity    Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  cart        Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  inventory   SellerInventory @relation(fields: [inventoryId], references: [id])

  @@unique([cartId, inventoryId])
  @@index([cartId])
  @@index([inventoryId])
  @@map("cart_items")
}

model EnterpriseUser {
  id                String             @id @default(uuid())
  enterpriseBuyerId String
  email             String             @unique
  firstName         String
  lastName          String
  role              EnterpriseUserRole
  spendingLimit     Float?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  enterpriseBuyer   Buyer              @relation(fields: [enterpriseBuyerId], references: [id], onDelete: Cascade)

  @@index([enterpriseBuyerId])
  @@index([email])
  @@map("enterprise_users")
}

model ExternalIntegration {
  id               String            @id @default(uuid())
  buyerId          String?
  sellerId         String?
  adminId          String?
  integrationType  IntegrationType
  name             String
  apiEndpoint      String?
  apiKey           String?
  clientId         String?
  clientSecret     String?
  webhookUrl       String?
  config           Json?
  isActive         Boolean           @default(false)
  status           IntegrationStatus @default(PENDING_SETUP)
  lastSyncAt       DateTime?
  syncStatus       String?
  syncError        String?           @db.Text
  rateLimitPerHour Int?              @default(1000)
  currentRateCount Int               @default(0)
  rateLimitResetAt DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  admin            Admin?            @relation(fields: [adminId], references: [id])
  buyer            Buyer?            @relation(fields: [buyerId], references: [id])
  seller           Seller?           @relation(fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([integrationType])
  @@index([status])
  @@index([adminId], map: "external_integrations_adminId_fkey")
  @@map("external_integrations")
}

model VinDecodeCache {
  id           String   @id @default(uuid())
  vin          String   @unique
  make         String
  model        String
  year         Int
  engine       String?
  transmission String?
  bodyStyle    String?
  fuelType     String?
  confidence   Float
  rawResponse  Json?
  decodedAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([vin])
  @@index([expiresAt])
  @@map("vin_decode_cache")
}

model SmsMessage {
  id               String    @id @default(uuid())
  recipient        String
  message          String    @db.Text
  templateId       String?
  gatewayProvider  String?
  gatewayMessageId String?
  gatewayStatus    String?
  status           String    @default("PENDING")
  sentAt           DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  failureReason    String?   @db.Text
  retryCount       Int       @default(0)
  maxRetries       Int       @default(3)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([createdAt])
  @@map("sms_messages")
}

model PaymentGatewayTransaction {
  id                   String    @id @default(uuid())
  orderId              String
  paymentId            String
  gatewayProvider      String
  gatewayTransactionId String    @unique
  gatewayResponse      Json?
  amount               Float
  currency             Currency
  gatewayFee           Float?
  status               String
  processedAt          DateTime?
  failedAt             DateTime?
  failureReason        String?   @db.Text
  webhookReceived      Boolean   @default(false)
  webhookData          Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  order                Order     @relation(fields: [orderId], references: [id])
  payment              Payment   @relation(fields: [paymentId], references: [id])

  @@index([orderId])
  @@index([gatewayTransactionId])
  @@index([status])
  @@index([paymentId], map: "payment_gateway_transactions_paymentId_fkey")
  @@map("payment_gateway_transactions")
}

model SavedSearch {
  id          String   @id @default(uuid())
  buyerId     String
  name        String
  description String?  @db.Text
  criteria    Json
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  buyer       Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
